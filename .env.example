PORT=8000
DATABASE_URL=postgres://px0:px0secret@localhost:5432/px0?sslmode=disable
REDIS_URL=redis://localhost:6379
SESSION_DURATION_HOURS=24
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# User Verification & Admin Access
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Search
#
# GET /v1/search accepts a natural-language q parameter and searches prompts,
# skills, and tools the requester is authorized to view. The server runs the
# configured full-text and vector retrievers independently, then combines
# their ranked candidates with reciprocal-rank fusion. See docs/search.md for
# index design, ranking behavior, and provider extension guidance.
#
# SEARCH_FTS_PROVIDER selects the lexical/full-text retriever.
# Supported now: postgres. Reserved: elasticsearch, opensearch, algolia.
# The server refuses to start when a reserved or unknown provider is selected;
# this prevents a typo or unfinished integration from silently weakening search.
SEARCH_FTS_PROVIDER=postgres

# SEARCH_VECTOR_PROVIDER selects the semantic/vector retriever.
# Use "none" to disable semantic retrieval while retaining PostgreSQL FTS.
# Reserved: qdrant, pinecone. As with FTS, selecting a reserved provider fails
# explicitly until its implementation is available.
SEARCH_VECTOR_PROVIDER=none

# Elasticsearch settings (used only when SEARCH_FTS_PROVIDER=elasticsearch).
# URL is the cluster base URL, API_KEY is a least-privilege credential, and
# INDEX is the index containing searchable registry entity documents.
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_INDEX=px0_search

# OpenSearch settings (used only when SEARCH_FTS_PROVIDER=opensearch).
# URL is the cluster base URL. USERNAME and PASSWORD authenticate requests.
# INDEX is the index containing prompts, skills, and tools.
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# OPENSEARCH_INDEX=px0_search

# Algolia settings (used only when SEARCH_FTS_PROVIDER=algolia).
# APP_ID identifies the Algolia application. API_KEY should be restricted to
# the configured index. INDEX_NAME stores searchable registry entities.
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX_NAME=px0_search

# Qdrant settings (used only when SEARCH_VECTOR_PROVIDER=qdrant).
# URL is the Qdrant HTTP endpoint. API_KEY authenticates hosted deployments.
# COLLECTION stores embeddings plus project_id and entity type payload filters.
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=px0_search

# Pinecone settings (used only when SEARCH_VECTOR_PROVIDER=pinecone).
# API_KEY authenticates the client. INDEX stores embeddings and authorization
# metadata for every searchable entity.
# PINECONE_API_KEY=
# PINECONE_INDEX=px0-search
