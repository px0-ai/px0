# px0 Application Configuration
# Copy this file to '.env' and configure your active settings.

# --- Server & Database Settings ---

# PORT: The TCP port where the HTTP server will bind.
# If already in use, the application will fail to start. Unix-like systems
# require administrative/root privileges to bind to ports below 1024.
PORT=8000

# DATABASE_URL: PostgreSQL connection string containing credentials and database.
# Note: Migrations run automatically on boot; the credentials must have full
# DDL permissions (CREATE, ALTER, INDEX, etc.). In production, do not use
# sslmode=disable. Ensure database max_connections covers the server pool size.
DATABASE_URL=postgres://px0:px0secret@localhost:5432/px0?sslmode=disable


# --- Redis Session Storage ---

# REDIS_URL: Redis connection string used for distributed session caching.
# If Redis is unreachable, the server will log a warning and fallback directly
# to PostgreSQL. While tolerant, this fallback significantly increases database
# CPU/latency under high request loads.
REDIS_URL=redis://localhost:6379

# SESSION_DURATION_HOURS: Longevity of active session tokens (sess_...).
# Lower values (1-12h) reduce token hijacking risk but increase login frequency.
SESSION_DURATION_HOURS=24


# --- Metrics & Telemetry ---

# OTEL_EXPORTER_OTLP_ENDPOINT: OpenTelemetry gRPC/HTTP collector endpoint.
# Logs a warning on failure but will not block server execution.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317


# --- Outbound Email (Resend) ---

# RESEND_API_KEY: Outbound transactional email key starting with "re_".
# If missing, invalid, or expired, user registration and resets will succeed
# in the DB but fail to dispatch verification codes, blocking user logins.
RESEND_API_KEY=your_resend_api_key_here

# RESEND_FROM_EMAIL: Verified sender email registered on your Resend dashboard.
# Must match a verified domain/address, otherwise email dispatch will fail.
RESEND_FROM_EMAIL=onboarding@resend.dev


# --- Registry Search (FTS & Vector) ---

# SEARCH_FTS_PROVIDER: Selects active full-text/lexical search backend.
# Options: postgres, elasticsearch, opensearch, algolia.
# Note: Selecting an unknown or reserved provider causes a fail-fast crash on boot.
# 'postgres' relies on real-time generated GIN indexes and is fully transactional.
SEARCH_FTS_PROVIDER=opensearch

# SEARCH_VECTOR_PROVIDER: Selects active semantic/vector search backend.
# Options: none (disabled, FTS only), qdrant, pinecone.
# Note: Selecting an unknown or reserved provider causes a fail-fast crash on boot.
SEARCH_VECTOR_PROVIDER=none

# Elasticsearch Settings (used when SEARCH_FTS_PROVIDER=elasticsearch)
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_INDEX=px0_search

# OpenSearch Settings (used when SEARCH_FTS_PROVIDER=opensearch)
OPENSEARCH_URL=http://localhost:9201
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=px0_search

# Algolia Settings (used when SEARCH_FTS_PROVIDER=algolia)
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX_NAME=px0_search

# Qdrant Settings (used when SEARCH_VECTOR_PROVIDER=qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=px0_search

# Pinecone Settings (used when SEARCH_VECTOR_PROVIDER=pinecone)
# PINECONE_API_KEY=
# PINECONE_INDEX=px0-search
